{
  "name": "pabakal",
  "version": "0.1.0",
  "description": "Pabakal — US-to-PH reseller storefront with cargo tracking and order management",
  "private": true,
  "packageManager": "pnpm@9.5.0",
  "scripts": {
    "preinstall": "node scripts/check-pnpm.cjs",
    "dev": "node scripts/check-pnpm.cjs && next dev --port 3200",
    "build": "node scripts/check-pnpm.cjs && next build",
    "start": "node scripts/check-pnpm.cjs && next start",
    "lint": "node scripts/check-pnpm.cjs && eslint --ext .ts,.tsx src/",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "seed": "tsx scripts/seed.ts"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "next": "^15.5.12",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.4.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "autoprefixer": "^10.4.24",
    "critters": "^0.0.25",
    "eslint": "^8",
    "eslint-config-next": "^15.5.12",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unicorn": "^56.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
